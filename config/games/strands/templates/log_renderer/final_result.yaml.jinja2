{%- macro format_answer(answer) -%}
{{ answer[0] }} [
{%- for x, y in answer[1] -%}
({{ x }}, {{ y }})
{%- if not loop.last %} -> {% endif -%}
{%- endfor -%}
]
{%- endmacro -%}
{%- set found_indices = final_result.found_indices -%}
{%- set answers = final_result.answers -%}
{%- set victory = found_indices|length == answers|length -%}
{%- set is_spangram_found = 0 in found_indices -%}
- key: Game Result
  value: {{ "victory" if victory else "failed"}}

- key: Is Spangram Found
  value: {{ "yes" if is_spangram_found else "no" }}

- key: {{ "Spangram" if is_spangram_found else "Spangram Not Found" }}
  value: |-
    {{ format_answer(answers[0]) }}

- key: Found Theme Words
  value: |-
    {% for index in found_indices|select("ne", 0) -%}
    {{ format_answer(answers[index]) }}
    {%- if not loop.last %}
    {% endif -%}
    {%- else -%}
    N/A
    {%- endfor %}

- key: Theme Words
  value: |-
    {% for answer in answers[1:] -%}
    {{ format_answer(answer) }}
    {%- if not loop.last %}
    {% endif -%}
    {%- else -%}
    N/A
    {%- endfor %}
